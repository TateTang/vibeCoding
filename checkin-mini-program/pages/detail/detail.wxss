.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top right, rgba(72, 138, 200, 0.14), transparent 30%),
    radial-gradient(circle at top left, rgba(67, 160, 71, 0.12), transparent 24%),
    linear-gradient(180deg, #f7f1e8 0%, #efe6d9 100%);
}

.summary-card,
.calendar-card,
.record-card,
.empty-state {
  border-radius: 28rpx;
  background: rgba(255, 252, 246, 0.94);
  box-shadow: 0 16rpx 40rpx rgba(88, 67, 43, 0.08);
}

.summary-card,
.calendar-card,
.records-section {
  margin-bottom: 24rpx;
}

.summary-card {
  padding: 28rpx;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.summary-main {
  flex: 1;
}

.project-name {
  display: block;
  margin-bottom: 12rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #2f2418;
}

.project-target {
  display: block;
  font-size: 24rpx;
  color: #8b7357;
}

.delete-button {
  min-width: 152rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fbede9;
  color: #c2410c;
  font-size: 24rpx;
  line-height: 64rpx;
  font-weight: 600;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  flex: 1;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f6ede0;
}

.summary-value {
  display: block;
  margin-bottom: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2418;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #8b7357;
}

.checkin-button {
  height: 84rpx;
  margin: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1f9d55 0%, #36b36e 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 84rpx;
  font-weight: 600;
}

.checkin-button.is-disabled {
  background: #d8d0c4;
  color: #6b7280;
}

.calendar-card {
  padding: 24rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.month-button {
  width: 72rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #f3e7d7;
  color: #6b5238;
  font-size: 42rpx;
  line-height: 72rpx;
}

.month-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #3b2a1d;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx 0;
}

.week-label,
.day-cell {
  text-align: center;
}

.week-label {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #8b7357;
}

.day-cell {
  min-height: 84rpx;
}

.day-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto;
  border: 4rpx solid transparent;
  border-radius: 22rpx;
  background: transparent;
}

.day-text {
  font-size: 26rpx;
  color: #4b3a2d;
}

.is-muted .day-text {
  color: #c0b2a1;
}

.day-badge.is-checked {
  background: #dff5e4;
}

.day-badge.is-checked .day-text {
  color: #1f7d43;
  font-weight: 700;
}

.day-badge.is-today {
  border-color: #3b82f6;
}

.day-badge.is-selected {
  box-shadow: 0 0 0 4rpx rgba(217, 119, 87, 0.16);
}

.note-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7f0e5;
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.note-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f2418;
}

.note-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.note-status.is-success {
  background: #dff5e4;
  color: #1f7d43;
}

.note-status.is-empty {
  background: #ece1cf;
  color: #8b7357;
}

.note-time {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #9b8469;
}

.note-content {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5d4a36;
}

.records-section {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3b2a1d;
}

.section-subtitle {
  font-size: 24rpx;
  color: #8b7357;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card {
  padding: 24rpx;
}

.record-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 14rpx;
}

.record-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #2f2418;
}

.record-created {
  font-size: 22rpx;
  color: #9b8469;
}

.record-note {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5d4a36;
}

.empty-state {
  padding: 64rpx 32rpx;
  text-align: center;
  color: #7e6a56;
  font-size: 28rpx;
}
