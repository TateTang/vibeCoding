.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 180rpx;
  background:
    radial-gradient(circle at top right, rgba(216, 119, 87, 0.18), transparent 32%),
    linear-gradient(180deg, #f7f1e8 0%, #f1e8db 100%);
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  background: #fff9f2;
  box-shadow: 0 18rpx 40rpx rgba(117, 84, 45, 0.08);
}

.hero-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: #9a7b58;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #3a2a1c;
}

.hero-date {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #efe4d2;
  font-size: 24rpx;
  color: #7a5f41;
}

.project-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.project-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 252, 246, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(88, 67, 43, 0.08);
}

.card-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.card-heading {
  flex: 1;
}

.project-name {
  display: block;
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2418;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
}

.status-checked {
  background: #1f9d55;
  color: #ffffff;
}

.status-pending {
  border: 2rpx solid #cfc3b1;
  background: #f7f0e5;
  color: transparent;
}

.status-text {
  font-size: 24rpx;
  color: #7a6752;
}

.checkin-button {
  min-width: 148rpx;
  height: 76rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d97757 0%, #c45739 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 76rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 22rpx rgba(196, 87, 57, 0.28);
}

.checkin-button.is-disabled {
  background: #d8d0c4;
  color: #6b7280;
  box-shadow: none;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-box {
  flex: 1;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f6ede0;
}

.stat-value {
  display: block;
  margin-bottom: 8rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2418;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #8b7357;
}

.progress-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #755d46;
}

.progress-track {
  overflow: hidden;
  height: 18rpx;
  border-radius: 999rpx;
  background: #e8dccb;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d97757 0%, #f1b06b 100%);
}

.empty-state {
  margin-top: 120rpx;
  padding: 64rpx 32rpx;
  border-radius: 32rpx;
  text-align: center;
  background: rgba(255, 251, 244, 0.92);
  box-shadow: 0 16rpx 36rpx rgba(88, 67, 43, 0.08);
}

.empty-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #33271a;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #7e6a56;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(243, 237, 227, 0) 0%, rgba(243, 237, 227, 0.96) 34%, #f3ede3 100%);
}

.add-button {
  height: 92rpx;
  border-radius: 999rpx;
  background: #2f2418;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 92rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 30rpx rgba(47, 36, 24, 0.18);
}
